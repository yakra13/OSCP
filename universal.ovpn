persist-tun
persist-key
tls-client
client
resolv-retry 5
connect-retry-max 1
explicit-exit-notify 1
remote-cert-tls server
nobind
remote-random
dev tun
ncp-ciphers AES-256-GCM:AES-256-CBC
cipher AES-256-CBC
auth SHA256
float
remote vpn-pool2.offseclabs.com 1194 udp
verify-x509-name "offensive-security.com" name
